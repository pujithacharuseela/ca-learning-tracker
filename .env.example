# ===========================================
# Personal Learning Tracker - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ===========================================

# -------------------------------------------
# Database (Supabase PostgreSQL)
# -------------------------------------------
DB_URL=jdbc:postgresql://db.kilomlgjuwffavhhembl.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-password-here

# -------------------------------------------
# JWT Configuration
# -------------------------------------------
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long-for-hmac-sha512

# -------------------------------------------
# Email (Gmail SMTP)
# -------------------------------------------
# Use Gmail App Password (not your regular password)
# Enable 2FA on Gmail, then generate App Password:
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# -------------------------------------------
# Application URLs
# -------------------------------------------
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8080/api

# -------------------------------------------
# Server Configuration
# -------------------------------------------
PORT=8080
BACKEND_PORT=8080
FRONTEND_PORT=3000
SPRING_PROFILES_ACTIVE=dev

# -------------------------------------------
# Render.com Deployment (Backend)
# -------------------------------------------
# Set these as environment variables in Render dashboard:
# DB_URL, DB_USERNAME, DB_PASSWORD, JWT_SECRET,
# MAIL_USERNAME, MAIL_PASSWORD, FRONTEND_URL,
# SPRING_PROFILES_ACTIVE=prod

# -------------------------------------------
# Vercel Deployment (Frontend)
# -------------------------------------------
# Set this in Vercel dashboard under Environment Variables:
# VITE_API_URL=https://your-backend.onrender.com/api
